meta {
  name: 배포 로그_v5
  type: http
  seq: 5
}

post {
  url: {{base_external_URL}}/restapi/get_deployment_log_v5
  body: json
  auth: bearer
}

auth:bearer {
  token: {{Token}}
}

body:json {
  {
      "mem_id": "koolsign_admin",
      "distinct": "true",
      "send_type": "예약",
      "limit": 10,
      "page": 1
  }
}

settings {
  encodeUrl: true
}
