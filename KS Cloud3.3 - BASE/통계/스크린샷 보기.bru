meta {
  name: 스크린샷 보기
  type: http
  seq: 11
}

post {
  url: {{base_external_URL}}/restapi/get_capture_status
  body: json
  auth: bearer
}

auth:bearer {
  token: {{Token}}
}

body:json {
  {
      "mem_id": "koolsign_admin", // 필수 
      "page": 1, // 필수
      "limit": 10, // 필수
      "stb_sn": "" // 검색
  }
}

settings {
  encodeUrl: true
}
