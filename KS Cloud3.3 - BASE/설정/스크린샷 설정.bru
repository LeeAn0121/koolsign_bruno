meta {
  name: 스크린샷 설정
  type: http
  seq: 2
}

post {
  url: {{base_external_URL}}/restapi/set_stb_capture
  body: json
  auth: bearer
}

auth:bearer {
  token: {{Token}}
}

body:json {
  {
      "mem_id": "koolsign_admin",
      "stb_sn": "KSU20100384",
      "capture_status": "Y",
      "capture_time": "01:00",
      "capture_size": "640*480"
  }
}

settings {
  encodeUrl: true
}
