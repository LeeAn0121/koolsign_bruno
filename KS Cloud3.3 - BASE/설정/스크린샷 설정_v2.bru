  token: {{Token}}
}

body:json {
  {
      "mem_id": "koolsign_admin",
      "stb_sn": "KSU24200249",
      "capture_status": "Y",
      "capture_time": "01:00",
      "capture_size": "640*480"
  }
}

settings {
  encodeUrl: true
}
